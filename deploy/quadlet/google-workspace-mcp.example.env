# Secrets + deployment URLs for the Google Workspace MCP server.
# Install to /etc/gateway/google-workspace-mcp.env (mode 0600) and fill in.
# Referenced by google-workspace-mcp.container via EnvironmentFile=.

# --- Google OAuth client (created once, by an admin) ---------------------------
# APIs & Services → Credentials → OAuth client ID → "Web application".
# Audience: Internal (no verification / no token expiry). Redirect URI on the
# client must be  <WORKSPACE_EXTERNAL_URL>/oauth2callback.
# Enable only the GA APIs you need (Gmail, Calendar, Drive, Docs, …) — NOT the
# *mcp.googleapis.com preview APIs.
GOOGLE_OAUTH_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=replace-me

# --- Public URL of THIS server (what the browser reaches during consent) -------
# Whatever your reverse proxy exposes for this container. Must be HTTPS in prod.
WORKSPACE_EXTERNAL_URL=https://gworkspace-mcp.example.com

# --- Allow the gateway's OAuth callback as a DCR redirect target ---------------
# This is the gateway's integrations callback, NOT this server's. FastMCP matches
# with `*` wildcards; comma-separate multiple entries.
WORKSPACE_MCP_ALLOWED_CLIENT_REDIRECT_URIS=https://gateway.example.com/integrations/callback,http://localhost:8080/integrations/callback
