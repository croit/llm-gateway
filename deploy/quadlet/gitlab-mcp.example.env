# Config for the self-managed GitLab MCP bridge (zereight/gitlab-mcp).
# Install to /etc/gateway/gitlab-mcp.env. Referenced via EnvironmentFile=.
# No secrets here — each user supplies their own GitLab token at connect time
# (remote-authorization mode); this only points the bridge at your instance.

# Your GitLab instance's REST API base (note the /api/v4 suffix).
GITLAB_API_URL=https://gitlab.example.com/api/v4
