# Copy to /etc/gateway/gateway.env and fill in. The Quadlet's
# `EnvironmentFile=` pulls everything in this file into the container's env.
# Permissions: chmod 0600 + chown root:root, since this holds long-lived
# secrets.

# 32 random bytes hex-encoded. Generate once:
#   openssl rand -hex 32
# Rotating this invalidates every existing browser session — users get
# bounced back to /login.
GATEWAY_SESSION_KEY=__replace_me__

# OIDC client secret. Name must match `[oidc].client_secret_env` in
# config.toml (defaults to GATEWAY_OIDC_CLIENT_SECRET in gateway.example.toml).
# Comment out + omit `[oidc]` from the config if you're standing up an
# auth-disabled local instance.
GATEWAY_OIDC_CLIENT_SECRET=__replace_me__

# Per-upstream-backend API keys. Each [[upstream_pools.<name>.backend]] entry
# that has `api_key_env = "FOO"` looks `FOO` up here. Examples:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
