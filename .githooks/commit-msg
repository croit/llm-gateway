#!/usr/bin/env bash
# commit-msg hook: reject AI/tool attribution trailers.
#
# This project does not want auto-appended AI/tool attributions in its
# history — neither `Co-authored-by:` lines nor `Claude-*:` trailers (e.g.
# `Claude-Session:`). The author/committer identity is the source of truth.
#
# Genuine override: `git commit --no-verify`.
set -euo pipefail

msg_file="$1"

# Match the git-canonical trailer case-insensitively, anchored to the start of
# a line (ignoring leading whitespace). Lines inside the commented/diff section
# git appends (with `-v`) start with '#', so a literal mention in a comment
# isn't a real trailer — but those are stripped before this runs anyway.
if grep -iEq '^[[:space:]]*Co-authored-by:' "$msg_file"; then
    echo "commit-msg: 'Co-authored-by:' trailers are not allowed in this repository." >&2
    echo "            Remove the trailer, or bypass with: git commit --no-verify" >&2
    exit 1
fi

# Same for AI/tool session-attribution trailers like `Claude-Session:`
# (any `Claude-<word>:` trailer).
if grep -iEq '^[[:space:]]*Claude-[A-Za-z0-9-]+:' "$msg_file"; then
    echo "commit-msg: 'Claude-*:' trailers (e.g. Claude-Session) are not allowed in this repository." >&2
    echo "            Remove the trailer, or bypass with: git commit --no-verify" >&2
    exit 1
fi
