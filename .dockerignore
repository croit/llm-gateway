target/
**/target/
# But the runtime Dockerfile needs the release binary from CI's
# `ci` job artifact — re-include it so the image build's COPY finds
# the file. Without this, the build logs "No files to copy" and the
# resulting image is missing /app/gateway.
!target/release/gateway
# typst CLI fetched into target/release/ by `mise run fetch-typst-cli`
# (transitive dep of the gateway build). Runtime Dockerfile COPYs it
# into /usr/local/bin/typst alongside /app/gateway.
!target/release/typst
# pdfium shared library fetched into target/release/ by `mise run
# fetch-pdfium` (transitive dep of the gateway build). Runtime
# Dockerfile COPYs it into /usr/local/lib/libpdfium.so for the
# fetch_attachment PDF reader's image tier. Without this re-include the
# build context omits it and the COPY fails ("libpdfium.so: not found").
!target/release/libpdfium.so
# Sandbox-runner binary (built by CI's `ci` job / `cargo build --release -p
# sandbox-runner`), COPYed by deploy/sandbox-runner/Containerfile.
!target/release/sandbox-runner
.git/
.gitignore
.github/
.vscode/
.idea/
.DS_Store
.env
.env.*
docs/
*.md
!crates/**/*.md
dist/
.mise/
